# ──────────────────────────────────────────────────────────────────────────
#  Copy to server/.env and fill in.  NEVER commit your real .env  (chmod 600)
# ──────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=production
PORT=3100
HOST=127.0.0.1
LOG_LEVEL=info

# Auth — long random strings. Generate each: openssl rand -hex 32
# Sessions last ~10 years and survive deploys, so keep AUTH_SECRET stable.
AUTH_SECRET=change-me-to-a-long-random-string
COOKIE_SECRET=change-me-too-another-random-string

# Learner accounts seeded on first run (JSON array). role: "user" | "admin".
SEED_USERS=[{"username":"alex","name":"Alex","password":"CHANGE_ME","role":"admin"}]
# Comma-separated usernames to always promote to admin (optional).
ADMIN_USERNAMES=

# Content / private assets (optional; sensible defaults if unset)
CONTENT_DIR=
TEXTBOOK_PDF=          # path to a private PDF served only via the auth-gated reader
LIBRARY_DIR=           # folder of graded-reader PDFs (per-level subfolders)

# Web Push reminders (optional). Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:you@example.com

# Translator / tap-to-translate. All optional — falls back to free MyMemory.
#  - LLM (best, context-aware): any OpenAI-compatible chat API.
LLM_TRANSLATE_URL=
LLM_TRANSLATE_KEY=
LLM_TRANSLATE_MODEL=gpt-4o-mini
#  - or a self-hosted LibreTranslate
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

# AI writing & speaking feedback (optional) — reuses the LLM_TRANSLATE_* endpoint.
# Override the model just for feedback if you want a stronger one:
LLM_CHECK_MODEL=

# Text-to-speech via ElevenLabs (optional — falls back to the browser voice).
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE=21m00Tcm4TlvDq8ikWAM   # default "Rachel"
ELEVENLABS_SPEED=0.85                   # 0.7–1.2; <1 = slower, measured pace
