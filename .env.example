# ---- Copy to .env and fill in. NEVER commit .env ----

# Secrets for signing auth tokens & cookies (use long random strings).
# Generate: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string
COOKIE_SECRET=change-me-too-another-random-string

# Accounts (JSON array). One object per learner.
SEED_USERS=[{"username":"vadim","name":"Вадим","password":"СМЕНИ_МЕНЯ"},{"username":"alena","name":"Алена","password":"СМЕНИ_МЕНЯ"}]

# Domain for Caddy (auto-HTTPS). Point this subdomain's DNS at the server first.
DOMAIN=lern.bobkov.cc
# Email for Let's Encrypt notifications (optional but recommended)
ACME_EMAIL=you@example.com

# Translator:
#  - Leave LIBRETRANSLATE_URL empty to use the free MyMemory API (no setup).
#  - Or run the bundled LibreTranslate service (docker compose --profile selfhost-translate up -d)
#    and set: LIBRETRANSLATE_URL=http://libretranslate:5000
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

# Best translation quality — context-aware (optional). Any OpenAI-compatible
# chat API (OpenAI, or a local Ollama / LM Studio / vLLM). When set it is tried
# first (picks the meaning that fits the sentence — "the train leaves" → отправляется,
# not листья) and falls back to LibreTranslate/MyMemory on any error.
LLM_TRANSLATE_URL=
LLM_TRANSLATE_KEY=
LLM_TRANSLATE_MODEL=gpt-5-nano

# App
NODE_ENV=production
PORT=3000
