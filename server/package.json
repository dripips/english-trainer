{
  "name": "english-trainer-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend (Fastify + node:sqlite) for the English trainer PWA",
  "main": "src/index.js",
  "scripts": {
    "start": "node --experimental-sqlite --disable-warning=ExperimentalWarning src/index.js",
    "dev": "node --experimental-sqlite --disable-warning=ExperimentalWarning --watch src/index.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.1.1",
    "fastify": "^5.2.1",
    "gray-matter": "^4.0.3",
    "web-push": "^3.6.7"
  }
}
